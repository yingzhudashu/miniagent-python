# Mini Agent — 示例环境变量（复制为 .env 后填写；勿提交真实密钥）
#
# 文档：docs/USER_GUIDE.md · docs/FEISHU.md · docs/ARCHITECTURE.md
#
# ── 1. API（必填）──
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# ── 2. 模型行为（可选；与 OpenClaw agents.defaults 对齐见 ARCHITECTURE.md）──
# MODEL_PROFILE=balanced
#   预设：creative / balanced / precise / code / fast
# AGENT_CONTEXT_WINDOW=128000
# OPENAI_MAX_TOKENS=
# AGENT_THINKING_DEFAULT=medium
# OPENAI_THINKING_BUDGET=
#   若两者都设置，预算以 OPENAI_THINKING_BUDGET 为准；档位由 AGENT_THINKING_DEFAULT 决定。
#
# ── 3. Agent 执行 ──
# AGENT_MAX_TURNS=400
# MINIAGENT_STEP_MAX_TURNS=48
#   分步执行时每步内 ReAct 子循环上限（未设置时默认 48）。
# MINIAGENT_THINKING_SEGMENT_SEPARATOR=
#   同一步内多轮思考正文拼接符；留空为双换行。
# MINIAGENT_TOOL_INTENT_MAX_CHARS=4000
# MINIAGENT_TOOL_INTENT_IN_THINKING=0
#   是否在工具执行前推送意图行；1/true 开启（默认关）。
# MINIAGENT_TOOL_FINISH_VERBOSE=0
#   1 时 on_tool_finish 落盘含参数与输出围栏。
# AGENT_TOOL_TIMEOUT=60
# AGENT_HTTP_TIMEOUT=120
# AGENT_CONTEXT_RESERVE=0.15
# AGENT_CONTEXT_COMPRESS_THRESHOLD=0.6
# AGENT_DEBUG=false
# AGENT_LOG_TOKEN_USAGE=true
# MINIAGENT_TASK_CLASSIFIER=1
# MINIAGENT_PHASED_EXECUTION=1
#
# LOOP_DETECTION_ENABLED=true
# LOOP_HISTORY_SIZE=50
# LOOP_WARNING_THRESHOLD=8
# LOOP_CRITICAL_THRESHOLD=12
#
# ── 4. 飞书凭证（python -m miniagent --feishu 时必填）──
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=
#   事件订阅加密（可选；与开放平台 Encrypt Key 一致）
#
# ── 5. 飞书体验与工具（推荐；未设置时代码默认与下行一致，除 DOT_COMMANDS_FULL）──
# MINIAGENT_FEISHU_REPLY_PLAIN=1
#   1/true：最终 Assistant 回复弱化部分 Markdown（仍为 interactive+lark_md）。
# MINIAGENT_FEISHU_REPLY_TARGET=reply
#   reply=回复入站 message_id；create=会话内新建消息。
# MINIAGENT_FEISHU_CARD_ACTION_ROUTER=1
#   1/true：注册卡片按钮回调（action.value 需 miniagent_text/text 与 chat_id）。
# MINIAGENT_FEISHU_TOOLS_AUTO=1
#   未设置 MINIAGENT_FEISHU_TOOLS 时：为 1 且已配置 FEISHU_APP_ID/SECRET 则自动注册（进程 init 即生效）。
#   或显式 MINIAGENT_FEISHU_TOOLS=1（见 docs/FEISHU.md）。
# FEISHU_DOC_FOLDER_FALLBACK_ROOT_META=1
#   无 folder_token 时尝试根目录元数据 API（默认开；需云盘权限）。
# MINIAGENT_FEISHU_DOT_COMMANDS_FULL=1
#   代码默认 0；设为 1 时飞书点命令与 CLI 同等（含 .session/.schedule/.stop；群聊误触风险见 FEISHU.md）。
#
# ── 6. 飞书进阶（一般保持默认即可；详表 docs/FEISHU.md）──
# MINI_AGENT_THINKING_FOR_LLM_MAX_CHARS=10000
# MINI_AGENT_FEISHU_CARD_BODY_MAX=48000
# MINIAGENT_FEISHU_TABLE_FALLBACK=both
# MINIAGENT_FEISHU_LARK_TABLE_MAX_PIPES=14
# MINIAGENT_FEISHU_MARKDOWN_COMMANDS=0
# MINIAGENT_FEISHU_REPLY_IN_THREAD=0
#   与 REPLY_TARGET=reply 联用；未设置且入站 thread_id 非空时默认话题内回复。
# MINIAGENT_FEISHU_RECEIVE_ID_TYPE=chat_id
# MINIAGENT_FEISHU_DOCX_URL_PREFIX=
# MINIAGENT_FEISHU_DOC_FOLDER_TOKEN=
# MINIAGENT_FEISHU_MEDIA_RUN_AGENT=0
# MINIAGENT_FEISHU_MEDIA_SILENT_REPLY=0
#
# ── 7. 飞书 WebSocket 长连接（docs/FEISHU.md「Windows / 长连接」）──
# MINIAGENT_FEISHU_WS_AUTO_RECONNECT=0
# MINIAGENT_FEISHU_WS_WATCHDOG_INTERVAL_S=30
# MINIAGENT_FEISHU_WS_DEAD_CONN_GRACE_S=90
# MINIAGENT_FEISHU_WS_RECONNECT_GRACE_S=300
# MINIAGENT_FEISHU_WS_REFRESH_INTERVAL_S=0
# MINIAGENT_FEISHU_WS_IDLE_REFRESH_S=0
#
# ── 8. 定时任务 / 联网 / CLI / 状态 ──
# MINIAGENT_DISABLE_SCHEDULED_TASKS=0
# MINIAGENT_SCHEDULE_DISPATCH_BACKOFF=60
# TZ=Asia/Shanghai
# MINIAGENT_TIMEZONE=Asia/Shanghai
#   与 TZ 二选一即可；修改后需重启进程。
# MINIAGENT_SCHEDULE_TIMEZONE=
#   仅覆盖定时任务默认时区；未设则与 MINIAGENT_TIMEZONE / TZ 一致。
# MINIAGENT_SCHEDULE_FEISHU_MIRROR=1
# MINIAGENT_SCHEDULE_FEISHU_LAST_CHAT=0
# MINIAGENT_SCHEDULE_TOOLS=1
#
# TAVILY_API_KEY=
# TAVILY_TIMEOUT=45
# BROWSER_TOOL_TIMEOUT=60
# pip install miniagent-python[browser] && playwright install chromium
#
# MINIAGENT_SELF_OPT_TOOLS=1
# MINIAGENT_CLI_DOT_TOOLS=1
# MINIAGENT_CLI_RAW_MARKDOWN=0
# MINIAGENT_CLI_THINKING_RICH=0
# MINIAGENT_WELCOME_CLI_HINT=1
#
# MINI_AGENT_STATE=workspaces
# MINI_AGENT_WORKSPACE=
# MINI_AGENT_SKILLS=
# MINI_AGENT_CONTEXT_TOOL_REDACT=1
#
# MINIAGENT_MCP_STDIO=["npx","-y","@some/mcp-server"]
# MINIAGENT_CONFIG=
#   可选外部 JSON（遗留）；日常请用上方扁平变量。曾用 MINIAGENT_OPENCLAW_CONFIG 仍会读取并打弃用警告。
