# Mini Agent — 示例环境变量（复制为 .env 后填写；勿提交真实密钥）
#
# 主配置面：以下扁平变量；可选 JSON 见文末（仅遗留兼容，非推荐）。
#
# ── API ──
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# ── 模型行为 ──
# MODEL_PROFILE=balanced
#   预设：creative / balanced / precise / code / fast（温度、top_p、默认 max_tokens 等；thinking 可被下方 env 覆盖）
#
# AGENT_CONTEXT_WINDOW：对应 OpenClaw agents.defaults.contextTokens（代理侧上下文预算）。
#   模型目录里的 contextWindow（厂商标称窗口，常更大）若需对齐，可改为该更大值，注意内存与费用。
#
# AGENT_THINKING_DEFAULT：low / medium / high，决定 thinking 档位（thinking_level）。
# OPENAI_THINKING_BUDGET：非负整数，决定 thinking token 预算；与 OpenClaw 常同时配置。
#   若两者都设置，最终预算以 OPENAI_THINKING_BUDGET 为准（档位仍由 AGENT_THINKING_DEFAULT）。
#   未设置 AGENT_THINKING_DEFAULT 时，可选外部 JSON 的按模型 thinking_budget 仍可生效。
#
# AGENT_CONTEXT_WINDOW=128000
# OPENAI_MAX_TOKENS=
# AGENT_THINKING_DEFAULT=medium
# OPENAI_THINKING_BUDGET=
#
# ── Agent ──
# AGENT_MAX_TURNS=20
# AGENT_TOOL_TIMEOUT=60
# AGENT_HTTP_TIMEOUT=120
# AGENT_CONTEXT_RESERVE=0.15
# AGENT_CONTEXT_COMPRESS_THRESHOLD=0.6
# AGENT_DEBUG=false
# AGENT_LOG_TOKEN_USAGE=true
# MINIAGENT_TASK_CLASSIFIER=1
# MINIAGENT_PHASED_EXECUTION=1
#
# ── 循环检测 ──
# LOOP_DETECTION_ENABLED=true
# LOOP_HISTORY_SIZE=50
# LOOP_WARNING_THRESHOLD=8
# LOOP_CRITICAL_THRESHOLD=12
#
# ── 可选遗留：外部 JSON（仅在未设置对应 env 时回填 OPENAI_* 等；thinking 仍以 env 优先）──
# MINIAGENT_CONFIG=D:/path/to/config.json
# 或 MINIAGENT_OPENCLAW_CONFIG=（同上，别名）
#
# ── 联网：Tavily + 浏览器（可选）──
# TAVILY_API_KEY=
# 或与 WEB_SEARCH_API_KEY 二选一（均作为 Tavily Key）
# WEB_SEARCH_API_KEY=
# TAVILY_TIMEOUT=45
# BROWSER_TOOL_TIMEOUT=60
# ^ 上两项单位为秒；浏览器导航超时将换算为毫秒（至少 5s）
#
# pip install miniagent-python[browser]
# playwright install chromium
#
# ── 自我优化工具（self_inspect / generate_proposal / run_tests / git_snapshot）──
# 默认开启；生产环境可关闭以降低暴露：MINIAGENT_SELF_OPT_TOOLS=0
#
# ── 技能目录（默认：仓库下 workspaces/skills）──
# 若旧版装在仓库根 skills/，请迁移到 workspaces/skills/ 或设置本变量指向旧目录
# MINI_AGENT_SKILLS=
#
# ── MCP（可选）──
# pip install miniagent-python[mcp]
# MINIAGENT_MCP_STDIO=["npx","-y","@some/mcp-server"]
#
# ── 状态目录 ──
# MINI_AGENT_STATE=workspaces
#
# TZ=Asia/Shanghai
