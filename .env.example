# Mini Agent — 示例环境变量（复制为 .env 后填写；勿提交真实密钥）
#
# 主配置面：以下扁平变量；可选 JSON 见文末（仅遗留兼容，非推荐）。
#
# ── API ──
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# ── 模型行为 ──
# MODEL_PROFILE=balanced
#   预设：creative / balanced / precise / code / fast（温度、top_p、默认 max_tokens 等；thinking 可被下方 env 覆盖）
#
# AGENT_CONTEXT_WINDOW：对应 OpenClaw agents.defaults.contextTokens（代理侧上下文预算）。
#   模型目录里的 contextWindow（厂商标称窗口，常更大）若需对齐，可改为该更大值，注意内存与费用。
#
# AGENT_THINKING_DEFAULT：low / medium / high，决定 thinking 档位（thinking_level）。
# OPENAI_THINKING_BUDGET：非负整数，决定 thinking token 预算；与 OpenClaw 常同时配置。
#   若两者都设置，最终预算以 OPENAI_THINKING_BUDGET 为准（档位仍由 AGENT_THINKING_DEFAULT）。
#   未设置 AGENT_THINKING_DEFAULT 时，可选外部 JSON 的按模型 thinking_budget 仍可生效。
#
# AGENT_CONTEXT_WINDOW=128000
# OPENAI_MAX_TOKENS=
# AGENT_THINKING_DEFAULT=medium
# OPENAI_THINKING_BUDGET=
#
# ── Agent ──
# AGENT_MAX_TURNS=400
#   提高上限会增加最坏情况下的费用与耗时；可按需调低。
# MINIAGENT_STEP_MAX_TURNS=48
#   分步执行时每步内 ReAct 子循环上限（未设置时默认 48）。
# MINIAGENT_THINKING_SEGMENT_SEPARATOR=
#   同一步内多轮思考正文拼接符；留空为双换行。可设为 \n\n---\n\n 恢复旧版横线分隔。
# MINIAGENT_TOOL_INTENT_MAX_CHARS=4000
#   工具意图行中 path/command 等预览最大字符；0 表示不截断。
# AGENT_TOOL_TIMEOUT=60
# AGENT_HTTP_TIMEOUT=120
# AGENT_CONTEXT_RESERVE=0.15
# AGENT_CONTEXT_COMPRESS_THRESHOLD=0.6
# AGENT_DEBUG=false
# AGENT_LOG_TOKEN_USAGE=true
# MINIAGENT_TASK_CLASSIFIER=1
# MINIAGENT_PHASED_EXECUTION=1
#
# ── CLI 终端（可选 Rich：pip install -e ".[cli]"）──
# MINIAGENT_CLI_RAW_MARKDOWN=1
#   为 1 时关闭 Assistant **最终回复** 的 Rich Markdown 渲染（便于复制调试）。
# MINIAGENT_CLI_THINKING_RICH=1
#   为 1 时对**非流式**思考片段尝试 Rich 渲染（全屏 TUI transcript 支持 ANSI 块；默认 0）。
# MINIAGENT_WELCOME_CLI_HINT=1
#   未安装 Rich 时是否在欢迎界面提示安装 .[cli]；0/false 关闭。
#
# ── 循环检测 ──
# LOOP_DETECTION_ENABLED=true
# LOOP_HISTORY_SIZE=50
# LOOP_WARNING_THRESHOLD=8
# LOOP_CRITICAL_THRESHOLD=12
#
# ── 可选遗留：外部 JSON（仅在未设置对应 env 时回填 OPENAI_* 等；thinking 仍以 env 优先）──
# MINIAGENT_CONFIG=D:/path/to/config.json
# 或 MINIAGENT_OPENCLAW_CONFIG=（同上，别名）
#
# ── 联网：Tavily + 浏览器（可选）──
# TAVILY_API_KEY=
# 或与 WEB_SEARCH_API_KEY 二选一（均作为 Tavily Key）
# WEB_SEARCH_API_KEY=
# TAVILY_TIMEOUT=45
# BROWSER_TOOL_TIMEOUT=60
# ^ 上两项单位为秒；浏览器导航超时将换算为毫秒（至少 5s）
#
# pip install miniagent-python[browser]
# playwright install chromium
#
# ── 自我优化工具（self_inspect / generate_proposal / run_tests / git_snapshot）──
# 默认开启；生产环境可关闭以降低暴露：MINIAGENT_SELF_OPT_TOOLS=0
#
# ── 点命令工具（run_dot_command：Agent 内调用与终端一致的 .help / .status 等）──
# 默认开启；设为 0/false/off 不在注册表注册该工具：MINIAGENT_CLI_DOT_TOOLS=0
#
# ── 定时任务（持久化 MINI_AGENT_STATE/scheduled_tasks/；进程内调度 + 消息队列执行）──
# 关闭后台调度循环（仍可用 .schedule / manage_scheduled_task 改任务表）：MINIAGENT_DISABLE_SCHEDULED_TASKS=1
# dispatch/包装失败时推迟下次触发的秒数（默认 60）：MINIAGENT_SCHEDULE_DISPATCH_BACKOFF=60
# 进程默认 IANA 时区（Agent get_time、定时任务新建默认、system 注入）；优先级见 timezone_config.py
# MINIAGENT_TIMEZONE=Asia/Shanghai
# 仅覆盖定时任务默认（未写 --tz 时）；未设置则与 MINIAGENT_TIMEZONE / TZ 一致
# MINIAGENT_SCHEDULE_TIMEZONE=Asia/Shanghai
# 与上二者等价时可只设：TZ=Asia/Shanghai（修改后需重启进程，尤其 Windows）
# primary 会话定时任务镜像到已绑定飞书（0/false 关闭）：MINIAGENT_SCHEDULE_FEISHU_MIRROR=1
# 无绑定时回退到最后活跃飞书 chat_id（默认关闭，需显式开启）：MINIAGENT_SCHEDULE_FEISHU_LAST_CHAT=1
# 不在注册表注册结构化工具 manage_scheduled_task：MINIAGENT_SCHEDULE_TOOLS=0
#
# ── 技能目录（默认：仓库下 workspaces/skills，已内置 skill-creator / skill-vetter）──
# 若旧版装在仓库根 skills/，请迁移到 workspaces/skills/ 或设置本变量指向旧目录
# MINI_AGENT_SKILLS=
#
# ── MCP（可选）──
# pip install miniagent-python[mcp]
# MINIAGENT_MCP_STDIO=["npx","-y","@some/mcp-server"]
#
# ── 会话 history.json / 飞书卡片 ──
# MINI_AGENT_THINKING_FOR_LLM_MAX_CHARS=10000
#   磁盘 thinking 全文保留；映射给下游 LLM 时截断至此长度；0 表示不截断。
# MINI_AGENT_FEISHU_CARD_BODY_MAX=48000
#   单张交互卡片 lark_md 正文近似上限（最终回复与思考 finalize 分片均参考此值）。
#   思考卡：流式 PATCH 与每次追加工具行时会对当前累积正文整体套用该上限；极长时较早内容可能被 … 截断（history.json 仍保留全文）。
# MINIAGENT_FEISHU_TABLE_FALLBACK=both
#   列数超过 MINIAGENT_FEISHU_LARK_TABLE_MAX_PIPES 的 GFM 表：both=提示+等宽文本表，unicode=仅文本表，hint=仅提示（默认 both）。
# MINIAGENT_FEISHU_LARK_TABLE_MAX_PIPES=14
#   表格行内管道符数量超阈值时触发上述降级（与 docs/FEISHU.md 一致）。
# MINIAGENT_FEISHU_MARKDOWN_COMMANDS=0
#   设为 1/true 时，飞书 capture 路径下 .session list / .queue status / .instance list 使用 GFM 表格输出。
# MINIAGENT_FEISHU_REPLY_PLAIN=0
#   为 1/true 时仅影响最终 Assistant 回复：仍为 interactive+lark_md，启发式去掉部分 ** / ``` / ` 等（不是 msg_type=text）。
# MINIAGENT_FEISHU_REPLY_TARGET=create
#   create=会话内新建消息（默认）；reply=对入站 message_id 使用「回复消息」API（思考卡与最终回复一致）。
# MINIAGENT_FEISHU_REPLY_IN_THREAD=0
#   与上一项 reply 联用：1/true 时传入 reply_in_thread（话题内回复）。
# MINIAGENT_FEISHU_CARD_ACTION_ROUTER=0
#   1/true 时注册卡片按钮回调：action.value 内需 miniagent_text/text 与 chat_id（或依赖回调 context）。
# MINIAGENT_FEISHU_TOOLS=0
#   1/true 时注册飞书内置工具：发文件/撤回/建文档/读 raw_content/列云盘/追加文档正文等（见 docs/FEISHU.md）。
# MINIAGENT_FEISHU_TOOLS_AUTO=0
#   为 1/true 且已配置 FEISHU_APP_ID + FEISHU_APP_SECRET 时，若未设置 MINIAGENT_FEISHU_TOOLS 则自动注册上述工具。
#   注册在进程启动加载内置工具时生效，不等待 .feishu start；仅 CLI 也会暴露 feishu_*（不需要时请勿开 AUTO 或显式 MINIAGENT_FEISHU_TOOLS=0）。
#   MINIAGENT_FEISHU_TOOLS 若设为非 1/true/yes/on 且非 0/false/no/off 的字符串，按关闭处理，不会回退到 AUTO。
# FEISHU_DOCX_URL_PREFIX=
# MINIAGENT_FEISHU_DOCX_URL_PREFIX=
#   二者任一：创建云文档工具成功时在输出中附带可分享链接，例如 https://your-tenant.feishu.cn/docx（末尾可有或无斜杠；与飞书 Web 端域名一致）。
# MINIAGENT_FEISHU_RECEIVE_ID_TYPE=chat_id
#   内置工具 create 消息时的 receive_id_type：chat_id | open_id | union_id（须与 receive_id 一致）。
# FEISHU_DEFAULT_DOC_FOLDER_TOKEN=
# MINIAGENT_FEISHU_DOC_FOLDER_TOKEN=
#   二者任一：feishu_create_document / feishu_list_drive_files 未传 folder_token（或仅传空）时的默认云盘父文件夹 token。
# FEISHU_DOC_FOLDER_FALLBACK_ROOT_META=0
#   为 1/true/on 时，在无参数且无上述环境变量时调用开放平台 drive/explorer/v2/root_folder/meta 获取根目录 token（默认关闭；需云盘权限；见 docs/FEISHU.md）。
# MINIAGENT_FEISHU_MEDIA_RUN_AGENT=0
#   1/true：图片/文件/post 落盘后追加合成用户消息并跑一轮 Agent（与 docs/FEISHU.md、docs/ENGINEERING.md 一致）。
# MINIAGENT_FEISHU_MEDIA_SILENT_REPLY=0
#   1/true：媒体落盘成功时不向飞书发自动回复（CLI 侧镜像不受影响）。
# MINIAGENT_TOOL_INTENT_IN_THINKING=1
#   是否在工具执行前推送 🔧 意图行；0/false 关闭。
# MINIAGENT_TOOL_FINISH_VERBOSE=1
#   设为 1 时 on_tool_finish 落盘含参数与输出围栏；默认 0 仅名称与成败。
#
# ── 状态目录与工作区 ──
# MINI_AGENT_STATE=workspaces
# MINI_AGENT_WORKSPACE=
#   无已加载会话时工具默认 cwd / allowlist 根（默认进程当前目录）；详见 docs/SECURITY.md、docs/ARCHITECTURE.md。
#
# MINI_AGENT_CONTEXT_TOOL_REDACT=1
#   默认开启：向 LLM 注入前将过长 tool 消息正文替换为占位说明；0/false/off 关闭（token 与隐私面增大）。
#
# TZ=Asia/Shanghai
