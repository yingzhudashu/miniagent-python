# MiniAgent Python 环境变量配置模板
#
# 使用方法：
# 1. 复制此文件为 .env（或直接修改 config.user.json）
# 2. 填写必填配置项（标记为 [必填]）
# 3. 可选配置项根据需要填写
#
# 配置优先级（从高到低）：
# 1. 单项环境变量（本文件）
# 2. config.user.json 的 secrets 部分
# 3. config.defaults.json（默认值）
#
# 详细说明见：docs/ENV_REFERENCE.md

# ============================================================================
# 1. API 凭据 [必填]
# ============================================================================

# LLM API 密钥 - 启动必须
OPENAI_API_KEY=sk-your-api-key-here

# API 基础 URL（可指向兼容 OpenAI 的第三方服务）
MINIAGENT_MODEL_BASE_URL=https://api.openai.com/v1

# 主模型名称
MINIAGENT_MODEL_MODEL=gpt-4o-mini

# Web 搜索 API 密钥（web_search 技能需要）
TAVILY_API_KEY=

# ============================================================================
# 2. 飞书配置（--feishu 启动时需要）
# ============================================================================

# 飞书应用凭据
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# 飞书用户访问令牌（feishu_doc action=search 需要）
MINIAGENT_FEISHU_USER_ACCESS_TOKEN=

# ============================================================================
# 3. 模型行为
# ============================================================================

# 上下文窗口大小（token 数）
MINIAGENT_MODEL_CONTEXT_WINDOW=128000

# 最大输出 token 数
MINIAGENT_MODEL_MAX_TOKENS=

# 思考档位：none/low/medium/high
MINIAGENT_MODEL_THINKING_LEVEL=medium

# 思考预算 token（仅某些模型支持）
MINIAGENT_MODEL_THINKING_BUDGET=

# ============================================================================
# 4. Agent 执行
# ============================================================================

# Agent 最大对话轮次
MINIAGENT_AGENT_MAX_TURNS=400

# 分步执行时每步 ReAct 子循环上限
MINIAGENT_STEP_MAX_TURNS=48

# 记忆存储最大缓存条目数
MINIAGENT_MEMORY_STORE_CACHE_MAX=100

# 关键词索引最大条目数
MINIAGENT_MEMORY_KEYWORD_INDEX_MAX=20000

# 单个工具超时秒数
MINIAGENT_AGENT_TOOL_TIMEOUT=60

# HTTP 请求超时秒数
MINIAGENT_AGENT_HTTP_TIMEOUT=120

# ============================================================================
# 5. 飞书核心体验
# ============================================================================

# 回复格式：0=完整 Markdown，1=弱化标记
MINIAGENT_FEISHU_REPLY_PLAIN=0

# 回复目标：reply=回复入站消息，create=新建消息
MINIAGENT_FEISHU_REPLY_TARGET=reply

# 卡片按钮回调：1=启用
MINIAGENT_FEISHU_CARD_ACTION_ROUTER=1

# 自动注册飞书工具：1=启用（需已配凭据）
MINIAGENT_FEISHU_TOOLS_AUTO=1

# ============================================================================
# 6. 飞书 WebSocket
# ============================================================================

# 自动重连：1=启用
MINIAGENT_FEISHU_WS_AUTO_RECONNECT=0

# 看门狗检测间隔（秒）
MINIAGENT_FEISHU_WS_WATCHDOG_INTERVAL_S=30

# ============================================================================
# 7. 定时任务
# ============================================================================

# 禁用定时任务：1=禁用
MINIAGENT_DISABLE_SCHEDULED_TASKS=0

# 时区设置（优先级：MINIAGENT_TIMEZONE > TZ > Asia/Shanghai）
TZ=Asia/Shanghai
MINIAGENT_TIMEZONE=

# ============================================================================
# 8. 嵌入搜索（语义记忆）
# ============================================================================

# 开启嵌入搜索：1/true
MINIAGENT_EMBEDDING_ENABLED=0

# 专用 embedding 服务 URL
MINIAGENT_EMBEDDING_BASE_URL=

# 专用 embedding 模型
MINIAGENT_EMBEDDING_MODEL=

# ============================================================================
# 9. 知识库
# ============================================================================

# 知识库根目录
MINIAGENT_KB_ROOT=workspaces/knowledge

# 自动挂载：1=启用
MINIAGENT_KB_AUTO_MOUNT=1

# ============================================================================
# 10. CLI / 状态 / 调试
# ============================================================================

# 运行时状态目录
MINIAGENT_PATHS_STATE_DIR=workspaces

# CLI 富文本 thinking 展示：1=启用
MINIAGENT_CLI_THINKING_RICH=0

# 监视技能目录变更：1=启用
MINIAGENT_SKILLS_WATCH=0

# 调试模式
AGENT_DEBUG=false