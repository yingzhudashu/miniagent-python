# MiniAgent 敏感凭据示例
#
# ⚠️ 此文件包含敏感信息，切勿提交到git！
# 使用方法：复制为 .env.secrets 并填写实际值
#
# ============================================================================
# API密钥
# ============================================================================

# OpenAI API密钥（必填）
OPENAI_API_KEY=

# Tavily API密钥（web_search工具可选）
TAVILY_API_KEY=

# Web搜索API密钥（可选，与TAVILY_API_KEY任一即可）
WEB_SEARCH_API_KEY=

# Embedding API密钥（可选，用于向量搜索）
MINIAGENT_EMBED_API_KEY=

# ============================================================================
# 飞书凭据（python -m miniagent --feishu 时必填）
# ============================================================================

# 飞书应用ID
FEISHU_APP_ID=

# 飞书应用密钥
FEISHU_APP_SECRET=

# 飞书验证令牌（事件回调验证）
FEISHU_VERIFICATION_TOKEN=

# 飞书加密密钥（可选，用于事件加密）
FEISHU_ENCRYPT_KEY=

# 飞书用户访问令牌（可选，OAuth场景）
MINIAGENT_FEISHU_USER_ACCESS_TOKEN=

# ============================================================================
# GitHub令牌（可选，用于技能导入）
# ============================================================================

GITHUB_TOKEN=