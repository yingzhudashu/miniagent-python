        <!-- ══════════════════════════════════════════════════ -->
        <mxCell id="400" value="&lt;b&gt;🔄 核心执行流程&lt;/b&gt;&lt;br&gt;&lt;hr&gt;1️⃣ 用户输入 (CLI/飞书)&lt;br&gt;2️⃣ MessageQueue 调度&lt;br&gt;3️⃣ UnifiedEngine 编排&lt;br&gt;4️⃣ Phase 1: Planner 规划&lt;br&gt;5️⃣ Phase 2: Executor ReAct&lt;br&gt;  ↳ Think → Act → Observe&lt;br&gt;6️⃣ 工具调用 (沙箱内)&lt;br&gt;7️⃣ 三层记忆读写&lt;br&gt;8️⃣ 返回最终回复" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#ffffd0;strokeColor=#cccc00;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1570" y="1000" width="240" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="401" value="&lt;b&gt;📊 关键数据流&lt;/b&gt;&lt;br&gt;&lt;hr&gt;━━ 主数据流&lt;br&gt;╌╌ 依赖 / 辅助&lt;br&gt;&lt;br&gt;&lt;b&gt;双通道接入:&lt;/b&gt;&lt;br&gt;CLI stdin ↔ run_cli_loop()&lt;br&gt;飞书 WS ↔ poll_server&lt;br&gt;&lt;br&gt;&lt;b&gt;消息队列模式:&lt;/b&gt;&lt;br&gt;🟢 queue: 按序处理&lt;br&gt;🔴 preemptive: 最新优先&lt;br&gt;&lt;br&gt;&lt;b&gt;多实例:&lt;/b&gt;&lt;br&gt;instances/ 注册表 + 心跳" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#ffffd0;strokeColor=#cccc00;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1570" y="1220" width="240" height="230" as="geometry"/>
        </mxCell>

