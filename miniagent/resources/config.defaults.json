{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "3.0.0",
  "_config_guide": {
    "usage": "复制为 config.user.json，仅覆盖 User 层中需个性化的键；Advanced 层一般保持默认",
    "user_sections": [
      "secrets",
      "llm",
      "paths",
      "features",
      "embedding",
      "timezone",
      "session",
      "mcp",
      "security",
      "scheduled_tasks",
      "scheduled_tools",
      "knowledge",
      "agent",
      "cli",
      "feishu",
      "debug",
      "agent_html"
    ],
    "advanced_sections": [
      "memory",
      "dream",
      "trace",
      "self_optimization"
    ]
  },

  "secrets": {
    "description": "敏感凭据（⚠️ 在 config.user.json 中填写，切勿提交到 git）",
    "llm": {
      "openai": {"api_key": null},
      "anthropic": {"api_key": null},
      "google": {"api_key": null}
    },
    "openai_api_key": null,
    "tavily_api_key": null,
    "web_search_api_key": null,
    "stack_exchange_key": null,
    "embed_api_key": null,
    "feishu_app_id": null,
    "feishu_app_secret": null,
    "feishu_verification_token": null,
    "feishu_encrypt_key": null,
    "feishu_user_access_token": null,
    "github_token": null,
    "agent_html_api_key": null
  },

  "llm": {
    "description": "LLM provider、模型 profile 与阶段角色绑定（User 层）",
    "providers": {
      "openai": {
        "driver": "openai",
        "base_url": "https://api.openai.com/v1",
        "credential": "openai",
        "api_key_env": "OPENAI_API_KEY",
        "headers": {},
        "options": {}
      }
    },
    "models": {
      "primary": {
        "provider": "openai",
        "model": "gpt-4o-mini",
        "api": "openai_responses",
        "context_window": 128000,
        "max_output_tokens": 16384,
        "capabilities": {
          "tools": true,
          "vision": true,
          "reasoning": false,
          "structured_output": true
        },
        "defaults": {},
        "pricing": {},
        "compatibility": {}
      }
    },
    "roles": {
      "default": "primary",
      "reasoning": "primary",
      "fast": "primary",
      "vision": "primary"
    },
    "catalog": {
      "refresh": "manual",
      "cache_ttl_hours": 24
    },
    "max_retries": 2
  },

  "model": {
    "description": "内部兼容参数；3.0 用户模型选择请使用 llm 节",
    "base_url": "https://api.openai.com/v1",
    "model": "gpt-4o-mini",
    "temperature": 0.7,
    "top_p": 1.0,
    "max_tokens": 4096,
    "thinking_level": "light",
    "thinking_budget": 1024,
    "context_window": 128000,
    "retry_count": 2,
    "service_tier": null,
    "wire_api": "chat_completions",
    "user_agent": null,
    "_guide": {
      "service_tier": "服务层级：auto(自动选择)、default(标准)、flex(灵活/低成本)",
      "wire_api": "传输协议：chat_completions（默认）或 responses",
      "user_agent": "可选 HTTP User-Agent；仅在兼容网关明确要求时设置"
    }
  },

  "paths": {
    "description": "路径配置（User 层）",
    "state_dir": "workspaces",
    "workspace": null,
    "skills_dir": null
  },

  "features": {
    "description": "功能开关（User 层）",
    "requirement_clarify": true,
    "reflection": true,
    "reflection_max_tokens": 512,
    "skills_watch": false,
    "tui_verbose_log": false,
    "config_hot_reload": false
  },

  "embedding": {
    "description": "嵌入搜索（User：开关与端点；Advanced：dimension/top_k 等调参）",
    "enabled": false,
    "base_url": null,
    "model": null,
    "dimension": 1536,
    "top_k": 8,
    "min_score": 0.3,
    "max_entries": 2000,
    "cache_max_size": 1000,
    "cache_ttl_seconds": 3600,
    "index_queue_max_size": 256,
    "index_concurrency": 2
  },

  "timezone": {
    "description": "时区（User：default；Advanced：default_fallback）",
    "default": "Asia/Shanghai",
    "default_fallback": "Asia/Shanghai"
  },

  "session": {
    "description": "会话配置（User 层）",
    "default_name": null,
    "continue_mode": false
  },

  "mcp": {
    "description": "MCP 接入（User 层）",
    "stdio_command": null,
    "stdio_env": null
  },

  "security": {
    "description": "安全配置（User 层）",
    "allowed_commands": null
  },

  "scheduled_tasks": {
    "description": "定时任务（User：开关/时区；Advanced：dispatch_backoff 等）",
    "disabled": false,
    "timezone": null,
    "feishu_mirror": true,
    "dispatch_backoff": 60,
    "feishu_last_chat": false
  },

  "scheduled_tools": {
    "description": "定时工具开关（User 层）",
    "enabled": true
  },

  "knowledge": {
    "description": "知识库（User：路径；Advanced：检索阶段参数）",
    "default_root": "workspaces/knowledge",
    "root": null,
    "auto_mount": true,
    "as_core": true,
    "top_k": 5,
    "max_chars": 8000,
    "max_file_chars": 50000,
    "planner_enabled": true,
    "planner_top_k": 3,
    "planner_max_chars": 4000,
    "clarifier_enabled": true,
    "clarifier_top_k": 3,
    "clarifier_max_chars": 4000,
    "classifier_enabled": true,
    "classifier_top_k": 3,
    "classifier_max_chars": 4000,
    "reflector_enabled": true,
    "reflector_top_k": 3,
    "reflector_max_chars": 4000,
    "auto_ingest_analyzed_files": true,
    "auto_ingest_kb_name": "_auto_file_analysis",
    "auto_ingest_max_file_chars": null,
    "executor_enabled": true,
    "executor_top_k": 3,
    "executor_max_chars": 4000
  },

  "agent": {
    "description": "Agent（User：max_turns/tool_timeout/debug；Advanced：超时/循环检测等）",
    "max_turns": 400,
    "tool_timeout": 60,
    "debug": false,
    "http_timeout": 120,
    "context_reserve_ratio": 0.15,
    "context_compress_threshold": 0.6,
    "allow_parallel_tools": true,
    "parallel_sessions": true,
    "max_parallel_sessions": 4,
    "max_questions": 3,
    "queue_mode": "queue",
    "log_token_usage": true,
    "loop_detection": {
      "enabled": true,
      "history_size": 50,
      "warning_threshold": 8,
      "critical_threshold": 12,
      "detectors": {
        "generic_repeat": true,
        "known_poll_no_progress": true,
        "ping_pong": true
      }
    }
  },

  "cli": {
    "description": "CLI 体验（User 层）",
    "dot_tools_enabled": true,
    "welcome_hint": true,
    "file_vision_desc": true,
    "input_history_max": 100,
    "force_fallback": false,
    "raw_markdown": false,
    "thinking_rich": false,
    "theme": "auto",
    "keybindings": {
      "model_selector": "c-p",
      "session_selector": "c-o",
      "toggle_reasoning": "c-r",
      "tasks": "c-t",
      "copy_mode": "c-m",
      "newline": "escape enter"
    }
  },

  "feishu": {
    "description": "飞书渠道（User：行为；Advanced：websocket/card 运维）",
    "reply_plain": false,
    "reply_target": "reply",
    "tools_auto": true,
    "tools_explicit": null,
    "dot_commands_full": false,
    "card_action_router": true,
    "card_extract_inbound": true,
    "markdown_commands": false,
    "reply_in_thread": null,
    "receive_id_type": "chat_id",
    "max_message_age": 600,
    "message_debounce_ms": 800,
    "media": {
      "run_agent": false,
      "vision_desc": true,
      "silent_reply": false
    },
    "doc": {
      "folder_token": null,
      "docx_url_prefix": null,
      "folder_fallback_root_meta": true
    },
    "websocket": {
      "auto_reconnect": false,
      "watchdog_interval": 30,
      "dead_conn_grace": 90,
      "reconnect_grace": 300,
      "stable_reset_after": 60,
      "refresh_interval": 0,
      "idle_refresh": 0
    },
    "card": {
      "thinking_max_chars": 10000,
      "body_max_chars": 48000
    }
  },

  "debug": {
    "description": "调试（User：perf_metrics；Advanced：session_id/log_path）",
    "perf_metrics": false,
    "session_id": null,
    "log_path": null
  },

  "agent_html": {
    "description": "Agent HTML 上传服务（User 层）",
    "base_url": "https://robotclaw.site",
    "max_size": 2097152,
    "_guide": {
      "base_url": "API 服务基础 URL",
      "max_size": "单文件最大字节数（默认 2MB）"
    }
  },

  "memory": {
    "description": "记忆容量与分层注入（Advanced 层）",
    "max_transcript_chars": 400000,
    "initial_history_count": 5,
    "history_progressive": true,
    "maintenance_max_iters": 3,
    "history_tail_messages": 200,
    "history_max_messages": 120,
    "archive_token_hint": null,
    "max_history_messages": 200,
    "store_cache_max": 200,
    "store_cache_ttl_seconds": 1800,
    "registry_max_entries": 3000,
    "keyword_index_max": 20000,
    "keyword_prune_interval": 86400,
    "context_tool_redact": true,
    "layered_inject": true,
    "layered_max_chars": 12000,
    "diary_preview_chars": 2000,
    "layered_session_lt": true,
    "layered_agent_lt": true,
    "thinking_for_llm_mode": "compact",
    "thinking_for_llm_compact_max_chars": 1200,
    "thinking_for_llm_max_chars": 10000
  },

  "dream": {
    "description": "记忆精炼调度（Advanced 层）",
    "diary_refine_sec": 604800,
    "session_lt_refine_sec": 2592000,
    "agent_lt_refine_sec": 31536000,
    "size_force_bytes": 800000,
    "min_schedule_interval_sec": 60
  },

  "trace": {
    "description": "Trace 持久化与清理（Advanced 层）",
    "enabled": false,
    "output_dir": "workspaces/logs",
    "retention_days": 7,
    "writer_batch_interval": 0.1,
    "writer_batch_size": 50,
    "writer_queue_max_size": 10000,
    "writer_overflow_policy": "drop_oldest",
    "record_payload": "metrics_only",
    "resource_sample_interval_seconds": 0,
    "stats_max_latency_samples": 100000,
    "stats_max_session_samples": 1000,
    "auto_cleanup": true,
    "cleanup_interval": 3600,
    "stats_report_interval": 3600
  },

  "self_optimization": {
    "description": "自我优化运维（Advanced 层）",
    "enabled": true,
    "auto_apply": false,
    "auto_apply_max_risk": "low",
    "proposal_output_dir": "workspaces/self_opt/proposals",
    "runtime_analysis_enabled": true,
    "code_analysis_enabled": true,
    "proposal_retention_days": 30,
    "min_failure_rate_threshold": 0.05,
    "min_duration_ms_threshold": 2000
  }
}
