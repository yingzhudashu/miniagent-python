__pycache__/
**/__pycache__/
.venv/
.mypy_cache/
.ruff_cache/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
state/

# 常见本地凭据文件（项目配置仍以 config.user.json 为准）
.env
.env.secrets
.env.backup

# 用户配置（敏感凭据）
config.user.json

# 本地调试日志与性能剖析产物（勿提交）
debug-*.log
perf-snapshot.json
real-api-snapshot.json
perf.out
profile.svg
trace-overhead.json
stability-soak.json

# 测试覆盖率产物
.coverage
.coverage.*
htmlcov/
coverage.xml
wheelhouse/

# Claude Code session 目录
.claude/

# IDE和编辑器
.vscode/
.idea/
.cursor/plans/

# 用户私有维护脚本（只保留目录说明）
scripts/user/*
!scripts/user/README.md

# 运行时工作目录（全部忽略，但保留示例文件）
workspaces/*
!workspaces/.gitkeep
workspaces/logs/

# 可选离线测评：轨迹与生成报告默认不入库（评测源码 *.py 可提交；详见 tests/evaluation/README_API_PERF.md）
tests/evaluation/runners/trajectories/
tests/evaluation/**/evaluation_results.json
docs/EVALUATION_REPORT.html
docs/evaluation_results.json
workspaces/skills/
!workspaces/skills/THIRD_PARTY_SKILLS.md
