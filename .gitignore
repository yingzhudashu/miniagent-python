__pycache__/
**/__pycache__/
.ruff_cache/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
state/
.env

# 本地调试日志（勿提交）
debug-*.log
perf-snapshot.json

# 运行时状态（按需取消注释；若团队将 workspaces 提交为示例可保留跟踪）
workspaces/instances/
workspaces/**/*.lock
workspaces/sessions/
workspaces/workspaces/
workspaces/cli/
workspaces/scheduled_tasks/

# 记忆索引、性能日志、飞书路由等运行时产物（默认不入库；需要示例请放 docs/examples/）
workspaces/memory/
workspaces/keyword-index.json
workspaces/perf*.jsonl
workspaces/feishu_inbound_owner.json
workspaces/feishu/

# 可选离线测评：轨迹与生成报告默认不入库（评测源码 *.py 可提交；详见 docs/EVALUATION_LOCAL.md）
tests/evaluation/runners/trajectories/
tests/evaluation/**/evaluation_results.json
docs/EVALUATION_REPORT.html
docs/evaluation_results.json
